# ══════════════════════════════════════════════════════
#  Hypatia Capital — Credenciais para Deploy Automático
#  Copie este arquivo para .env.setup e preencha tudo.
#  NUNCA commite o arquivo .env.setup no GitHub.
# ══════════════════════════════════════════════════════

# ─── SUPABASE ──────────────────────────────────────────
# Onde obter: https://app.supabase.com/account/tokens
# Clique em "Generate new token" → dê o nome "deploy"
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Senha do banco PostgreSQL (crie uma senha forte, ex: MinhaS3nh@2026!)
# Você vai precisar dela só se acessar o banco diretamente
SUPABASE_DB_PASSWORD=MinhaS3nh@Forte2026

# ─── GITHUB ────────────────────────────────────────────
# Onde obter: https://github.com/settings/tokens/new
# Marque as permissões: repo (todas), workflow
# Validade: 90 days (ou sem validade)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── VERCEL ────────────────────────────────────────────
# Onde obter: https://vercel.com/account/tokens
# Clique em "Create Token" → nome "hypatia-deploy" → Full Access
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── CONFIGURAÇÃO DO SITE ──────────────────────────────
# Seu email de admin (quem acessa o painel de upload)
ADMIN_EMAIL=seuemail@hypatiacapital.com.br

# URL final do site (com https, sem barra no final)
SITE_URL=https://hypatiacapital.com.br
