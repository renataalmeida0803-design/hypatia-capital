# Copie este arquivo para .env.local e preencha os valores

# Supabase — obter em https://supabase.com > seu projeto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Email do advisor (você) — unico com acesso ao /admin
NEXT_PUBLIC_ADMIN_EMAIL=seuemail@hypatiacapital.com.br

# URL de producao (para o magic link funcionar corretamente)
NEXT_PUBLIC_SITE_URL=https://hypatiacapital.com.br
